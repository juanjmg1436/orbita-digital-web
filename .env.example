# Variables de entorno de ÓRBITA Digital.
# Copiá este archivo como .env.local y completá los valores reales.
# NUNCA subas .env.local (ni ningún archivo con credenciales reales) al repositorio.

# URL del proyecto de Supabase (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima / publishable de Supabase (Project Settings > API > anon public)
# Es segura para exponer en el navegador: el acceso real lo controlan las
# políticas de Row Level Security de cada tabla.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key de Supabase (Project Settings > API > service_role).
# Solo para uso futuro en funciones de servidor/administración segura.
# NUNCA debe usarse en el cliente ni en variables NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública donde queda publicado el sitio (sin barra final).
# En desarrollo: http://localhost:3000
# En producción: la URL de Vercel o el dominio propio.
NEXT_PUBLIC_SITE_URL=

# Clave de API de Resend (resend.com > API Keys), para avisar por email
# cuando llega una consulta nueva. Opcional: si queda vacía, el formulario
# sigue funcionando igual, simplemente no se envía el aviso por email.
RESEND_API_KEY=
